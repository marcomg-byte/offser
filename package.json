{
  "name": "offser",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "backup:logs": "npx cpy logs/**/*.log backup/logs --parents",
    "build": "npx tsc && npm run build:templates && npm run build:certs",
    "build:templates": "npx cpy src/templates/**/* dist/templates --parents",
    "build:certs": "npx cpy src/config/certs/**/* dist/config/certs --parents",
    "clean": "rimraf dist",
    "clean:logs": "rimraf logs",
    "dev": "concurrently \"npm run watch:templates\" \"nodemon --watch src --ext ts --exec tsx src/index.ts\"",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "prepare": "npm run clean && npm run build",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "watch:templates": "nodemon --watch src/templates --ext hbs --exec \"npm run build:templates\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "handlebars": "^4.7.8",
    "nodemailer": "^7.0.12",
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/express": "^5.0.6",
    "@types/handlebars": "^4.0.40",
    "@types/node": "^25.0.3",
    "@types/nodemailer": "^7.0.4",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.0.18",
    "cpy-cli": "^6.0.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "nodemon": "^3.1.11",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.2",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.52.0",
    "vitest": "^4.0.18"
  }
}
