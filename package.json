{
  "name": "offser",
  "version": "1.0.0",
  "description": "A TypeScript Express server for email delivery, template rendering, and database management — for authorized security testing.",
  "keywords": ["security", "pentest", "smtp", "email", "express", "mysql", "red-team", "offensive-security"],
  "author": "marcomg-byte",
  "repository": {
    "type": "git",
    "url": "https://github.com/marcomg-byte/offser"
  },
  "main": "cli/index.js",
  "bin": {
    "offser": "cli/index.js"
  },
  "files": [
    "cli/"
  ],
  "scripts": {
    "backup:logs": "npx cpy logs/**/*.log backup/logs --parents",
    "build": "npx tsc && npm run templates:dist",
    "build:container": "docker build -f Dockerfile -t offser:latest .",
    "templates:dist": "npx cpy src/templates/**/* dist/templates --parents",
    "templates:bundle": "npx cpy src/templates/**/* bundle/templates --parents",
    "templates:cli": "npx cpy src/templates/**/* cli/templates --parents",
    "bundle:container": "node esbuild.container.mjs && npm run templates:bundle",
    "bundle:cli": "node esbuild.cli.mjs && npm run templates:cli",
    "clean": "rimraf dist bundle cli coverage",
    "clean:logs": "rimraf logs",
    "dev": "concurrently \"npm run watch:templates\" \"nodemon --watch src --ext ts --exec tsx src/index.ts\"",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "prepare": "npm run bundle:cli",
    "start": "node dist/index.js",
    "start:container": "docker run --env-file .env.container -p 8080:8080 -v $(pwd)/certs:/app/certs offser",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:clean": "rimraf coverage",
    "watch:templates": "nodemon --watch src/templates --ext hbs --exec \"npm run templates:dist\""
  },
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "handlebars": "^4.7.8",
    "mysql2": "^3.18.2",
    "nodemailer": "^7.0.12",
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/express": "^5.0.6",
    "@types/handlebars": "^4.0.40",
    "@types/node": "^25.0.3",
    "@types/nodemailer": "^7.0.4",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.0.18",
    "cpy-cli": "^6.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "nodemon": "^3.1.11",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.2",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.52.0",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "mysql2": "^3.18.2",
    "pino-pretty": "^13.1.3"
  }
}
