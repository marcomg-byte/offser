<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <link rel="icon" type="image/x-icon" href="/assets/matrix.ico">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Offser</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: #0d0208;
            color: #00ff41;
            font-family: 'Courier New', Consolas, monospace;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 20px;
            overflow: hidden;
        }

        .matrix-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(180deg, #0d0208 0%, #001a00 100%);
            z-index: -1;
        }

        .matrix-bg::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: 
                repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0, 255, 65, 0.03) 2px, rgba(0, 255, 65, 0.03) 4px);
            animation: scan 8s linear infinite;
        }

        @keyframes scan {
            0% { transform: translateY(0); }
            100% { transform: translateY(20px); }
        }

        @keyframes glow {
            0%, 100% { text-shadow: 0 0 10px #00ff41, 0 0 20px #00ff41, 0 0 30px #00ff41; }
            50% { text-shadow: 0 0 20px #00ff41, 0 0 30px #00ff41, 0 0 40px #00ff41; }
        }

        @keyframes flicker {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.8; }
        }

        .header {
            text-align: center;
            margin-bottom: 30px;
            z-index: 10;
        }

        .header h1 {
            font-size: 2.5rem;
            animation: glow 2s ease-in-out infinite;
            letter-spacing: 4px;
            margin-bottom: 10px;
        }

        .header .subtitle {
            display: flex;
            flex-flow: row nowrap;
            align-items: center;
            justify-content: space-evenly;
            font-size: 1rem;
            color: #00cc33;
            letter-spacing: 2px;
        }

        .dashboard-container {
            width: 100%;
            max-width: 1200px;
            height: 70vh;
            background: rgba(0, 0, 0, 0.8);
            border: 2px solid #00ff41;
            border-radius: 10px;
            box-shadow: 
                0 0 20px rgba(0, 255, 65, 0.3),
                inset 0 0 20px rgba(0, 255, 65, 0.1);
            overflow-y: auto;
            overflow-x: hidden;
            padding: 20px;
            animation: flicker 3s ease-in-out infinite;
            z-index: 10;
        }

        .dashboard-container::-webkit-scrollbar {
            width: 12px;
        }

        .dashboard-container::-webkit-scrollbar-track {
            background: #001a00;
            border-radius: 10px;
        }

        .dashboard-container::-webkit-scrollbar-thumb {
            background: #00ff41;
            border-radius: 10px;
            box-shadow: 0 0 10px #00ff41;
        }

        .dashboard-container::-webkit-scrollbar-thumb:hover {
            background: #00cc33;
        }

        .data-grid {
            display: grid;
            gap: 15px;
        }

        .data-item {
            background: rgba(0, 26, 0, 0.5);
            border: 1px solid #00ff41;
            border-radius: 5px;
            padding: 20px;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .data-item::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: linear-gradient(
                45deg,
                transparent,
                rgba(0, 255, 65, 0.1),
                transparent
            );
            transform: rotate(45deg);
            transition: all 0.5s ease;
        }

        .data-item:hover {
            border-color: #33ff77;
            box-shadow: 0 0 20px rgba(0, 255, 65, 0.5);
            transform: translateY(-2px);
        }

        .data-item:hover::before {
            left: 100%;
        }

        .data-row {
            display: grid;
            grid-template-columns: 100px 1fr 1fr;
            gap: 20px;
            align-items: center;
            position: relative;
            z-index: 1;
        }

        .data-label {
            font-weight: bold;
            color: #00ff41;
            text-transform: uppercase;
            font-size: 0.85rem;
            letter-spacing: 1px;
        }

        .data-value {
            color: #99ff99;
            word-break: break-all;
            padding: 5px 10px;
            background: rgba(0, 0, 0, 0.3);
            border-radius: 3px;
            border-left: 3px solid #00ff41;
        }

        .id-badge {
            display: inline-block;
            background: #00ff41;
            color: #0d0208;
            padding: 5px 15px;
            border-radius: 20px;
            font-weight: bold;
            box-shadow: 0 0 10px rgba(0, 255, 65, 0.5);
        }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: #00cc33;
            font-size: 1.2rem;
        }

        .empty-state::before {
            content: '⚠';
            display: block;
            font-size: 3rem;
            margin-bottom: 20px;
            animation: glow 2s ease-in-out infinite;
        }

        @media (max-width: 768px) {
            .header h1 {
                font-size: 1.8rem;
            }

            .data-row {
                grid-template-columns: 1fr;
                gap: 10px;
            }

            .dashboard-container {
                height: 80vh;
                padding: 15px;
            }
        }

        .export-btn {
            background: #00ff41;
            color: #0d0208;
            border: none;
            padding: 12px 20px;
            border-radius: 25px;
            font-family: 'Courier New', Consolas, monospace;
            font-weight: bold;
            font-size: 0.8rem;
            text-transform: uppercase;
            cursor: pointer;
            box-shadow: 0 0 20px rgba(0, 255, 65, 0.6);
            transition: all 0.3s ease;
            letter-spacing: 2px;
        }

        .export-btn:hover {
            background: #33ff77;
            box-shadow: 0 0 30px rgba(0, 255, 65, 0.9);
            transform: scale(1.05);
        }

        .export-btn:active {
            transform: scale(0.95);
        }

        @media (max-width: 768px) {
            /* ...existing code... */
            
            .export-btn {
                padding: 12px 25px;
                font-size: 0.9rem;
            }
        }
    </style>
</head>
<body>
    <div class="matrix-bg"></div>
    
    <div class="header">
        <h1>◈ PASSWORDS DASHBOARD ◈</h1>
        <div class="subtitle">
            ACCESS GRANTED // SYSTEM ONLINE
            {{#if data}}
                <button class="export-btn" onclick="exportRecords()">Export CSV</button>

                <script>
                    function exportRecords() {
                        const csvData = `{{{toCSV data}}}`;
                        const blob = new Blob([csvData], { type: 'text/csv;charset=utf-8;' });
                        const link = document.createElement('a');
                        const url = URL.createObjectURL(blob);

                        link.setAttribute('href', url);
                        link.setAttribute('download', 'password_records.csv');
                        link.style.visibility = 'hidden';
                        document.body.appendChild(link);
                        link.click();
                        document.body.removeChild(link);
                    }
                </script>
            {{/if}}
        </div>
    </div>

    <div class="dashboard-container">
        <div class="data-grid">
            {{#if data}}
                {{#each data}}
                <div class="data-item">
                    <div class="data-row">
                        <div>
                            <div class="data-label">ID</div>
                            <span class="id-badge">{{this.id}}</span>
                        </div>
                        <div>
                            <div class="data-label">Email</div>
                            <div class="data-value">{{this.mail}}</div>
                        </div>
                        <div>
                            <div class="data-label">Password</div>
                            <div class="data-value">{{this.password}}</div>
                        </div>
                    </div>
                </div>
                {{/each}}
            {{else}}
                <div class="empty-state">
                    NO DATA AVAILABLE IN THE SYSTEM
                </div>
            {{/if}}
        </div>
    </div>
</body>
</html>
