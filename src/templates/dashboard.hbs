<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <link rel="icon" type="image/x-icon" href="/assets/matrix.ico">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Offser</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: #0d0208;
            color: #00ff41;
            font-family: 'Courier New', Consolas, monospace;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 20px;
            overflow: hidden;
        }

        .matrix-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(180deg, #0d0208 0%, #001a00 100%);
            z-index: -1;
        }

        .matrix-bg::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: 
                repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0, 255, 65, 0.03) 2px, rgba(0, 255, 65, 0.03) 4px);
            animation: scan 8s linear infinite;
        }

        @keyframes scan {
            0% { transform: translateY(0); }
            100% { transform: translateY(20px); }
        }

        @keyframes glow {
            0%, 100% { text-shadow: 0 0 10px #00ff41, 0 0 20px #00ff41, 0 0 30px #00ff41; }
            50% { text-shadow: 0 0 20px #00ff41, 0 0 30px #00ff41, 0 0 40px #00ff41; }
        }

        @keyframes flicker {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.8; }
        }

        .header {
            text-align: center;
            margin-bottom: 30px;
            z-index: 10;
        }

        .header h1 {
            font-size: 2.5rem;
            animation: glow 2s ease-in-out infinite;
            letter-spacing: 4px;
            margin-bottom: 10px;
        }

        .header .subtitle {
            display: flex;
            flex-flow: row nowrap;
            align-items: center;
            justify-content: space-evenly;
            font-size: 1rem;
            color: #00cc33;
            letter-spacing: 2px;
        }

        .search-bar {
            display: flex;
            align-items: center;
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid #00ff41;
            border-radius: 25px;
            padding: 6px 16px;
            margin-left: 24px;
            margin-right: 24px;
            box-shadow: 0 0 10px rgba(0, 255, 65, 0.2);
            transition: border 0.2s;
        }
        .search-bar:focus-within {
            border-color: #33ff77;
        }
        .search-bar input[type="text"] {
            background: transparent;
            border: none;
            outline: none;
            color: #00ff41;
            font-family: 'Courier New', Consolas, monospace;
            font-size: 1rem;
            width: 160px;
            padding: 6px 8px 6px 0;
        }
        .search-bar .search-icon {
            font-size: 1.2rem;
            margin-left: 8px;
            color: #00ff41;
            pointer-events: none;
            user-select: none;
        }

        .dashboard-container {
            width: 100%;
            max-width: 1200px;
            height: 70vh;
            background: rgba(0, 0, 0, 0.8);
            border: 2px solid #00ff41;
            border-radius: 10px;
            box-shadow: 
                0 0 20px rgba(0, 255, 65, 0.3),
                inset 0 0 20px rgba(0, 255, 65, 0.1);
            overflow-y: auto;
            overflow-x: hidden;
            padding: 20px;
            animation: flicker 3s ease-in-out infinite;
            z-index: 10;
        }

        .dashboard-container::-webkit-scrollbar {
            width: 12px;
        }

        .dashboard-container::-webkit-scrollbar-track {
            background: #001a00;
            border-radius: 10px;
        }

        .dashboard-container::-webkit-scrollbar-thumb {
            background: #00ff41;
            border-radius: 10px;
            box-shadow: 0 0 10px #00ff41;
        }

        .dashboard-container::-webkit-scrollbar-thumb:hover {
            background: #00cc33;
        }

        .data-grid {
            display: grid;
            gap: 15px;
        }

        .data-item {
            background: rgba(0, 26, 0, 0.5);
            border: 1px solid #00ff41;
            border-radius: 5px;
            padding: 20px;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .delete-btn {
            position: absolute;
            top: 12px;
            right: 16px;
            background: rgba(13,2,8,0.95);
            color: #00ff41;
            border: 2px solid #00ff41;
            border-radius: 50%;
            width: 32px;
            height: 32px;
            font-size: 1.2rem;
            font-weight: bold;
            cursor: pointer;
            box-shadow: 0 0 12px #00ff41, 0 0 4px #00ff41 inset;
            transition: background 0.2s, color 0.2s, border 0.2s, box-shadow 0.2s;
            z-index: 2;
            outline: none;
            text-shadow: 0 0 6px #00ff41, 0 0 2px #00ff41;
        }
        .delete-btn:hover, .delete-btn:focus {
            background: #001a00;
            color: #0d0208;
            border-color: #33ff77;
            box-shadow: 0 0 24px #33ff77, 0 0 8px #33ff77 inset;
        }
        }

        .data-item::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: linear-gradient(
                45deg,
                transparent,
                rgba(0, 255, 65, 0.1),
                transparent
            );
            transform: rotate(45deg);
            transition: all 0.5s ease;
        }

        .data-item:hover {
            border-color: #33ff77;
            box-shadow: 0 0 20px rgba(0, 255, 65, 0.5);
            transform: translateY(-2px);
        }

        .data-item:hover::before {
            left: 100%;
        }

        .data-row {
            display: grid;
            grid-template-columns: 100px 1fr 1fr;
            gap: 20px;
            align-items: center;
            position: relative;
            z-index: 1;
        }

        .data-label {
            font-weight: bold;
            color: #00ff41;
            text-transform: uppercase;
            font-size: 0.85rem;
            letter-spacing: 1px;
        }

        .data-value {
            color: #99ff99;
            word-break: break-all;
            padding: 5px 10px;
            background: rgba(0, 0, 0, 0.3);
            border-radius: 3px;
            border-left: 3px solid #00ff41;
        }

        .id-badge {
            display: inline-block;
            background: #00ff41;
            color: #0d0208;
            padding: 5px 15px;
            border-radius: 20px;
            font-weight: bold;
            box-shadow: 0 0 10px rgba(0, 255, 65, 0.5);
        }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: #00cc33;
            font-size: 1.2rem;
        }

        .empty-state::before {
            content: '⚠';
            display: block;
            font-size: 3rem;
            margin-bottom: 20px;
            animation: glow 2s ease-in-out infinite;
        }

        @media (max-width: 768px) {
            .header h1 {
                font-size: 1.8rem;
            }

            .data-row {
                grid-template-columns: 1fr;
                gap: 10px;
            }

            .dashboard-container {
                height: 80vh;
                padding: 15px;
            }
        }

        .export-btn {
            background: #00ff41;
            color: #0d0208;
            border: none;
            padding: 12px 20px;
            border-radius: 25px;
            font-family: 'Courier New', Consolas, monospace;
            font-weight: bold;
            font-size: 0.8rem;
            text-transform: uppercase;
            cursor: pointer;
            box-shadow: 0 0 20px rgba(0, 255, 65, 0.6);
            transition: all 0.3s ease;
            letter-spacing: 2px;
        }

        .export-btn:hover {
            background: #33ff77;
            box-shadow: 0 0 30px rgba(0, 255, 65, 0.9);
            transform: scale(1.05);
        }

        .export-btn:active {
            transform: scale(0.95);
        }

        @media (max-width: 768px) {
            /* ...existing code... */
            
            .export-btn {
                padding: 12px 25px;
                font-size: 0.9rem;
            }
        }
    </style>
</head>
<body>
    <div class="matrix-bg"></div>
    <div id="matrix-snackbar" style="display:none;min-width:260px;max-width:90vw;background:#001a00;color:#00ff41;text-align:center;border-radius:8px;padding:16px 24px;position:fixed;left:50%;bottom:40px;transform:translateX(-50%);font-size:1.05rem;box-shadow:0 2px 18px #00ff41a0;z-index:9999;opacity:0;transition:opacity 0.3s, bottom 0.3s;letter-spacing:0.01em;border:2px solid #00ff41;text-shadow:0 0 8px #00ff41;">
        <span id="matrix-snackbar-message">Error</span>
        <button id="matrix-snackbar-confirm" style="display:none;margin-left:18px;background:#00ff41;color:#001a00;border:none;border-radius:5px;padding:6px 18px;font-weight:bold;cursor:pointer;box-shadow:0 0 8px #00ff41;transition:background 0.2s;">Confirm</button>
        <button id="matrix-snackbar-close" style="display:none;background:transparent;border:none;color:#00ff41;font-size:1.2rem;position:absolute;top:8px;right:14px;cursor:pointer;line-height:1;text-shadow:0 0 8px #00ff41;">&times;</button>
    </div>
    <div class="header">
        <h1>◈ PASSWORDS DASHBOARD ◈</h1>
        <div class="subtitle">
            ACCESS GRANTED // SYSTEM ONLINE
            <div class="search-bar">
                <input type="text" id="searchInput" placeholder="Search..." oninput="filterRecords()" />
                <span class="search-icon">🔍</span>
            </div>
            {{#if data}}
                <button class="export-btn" onclick="exportRecords()">Export CSV</button>
                <script>
                    function exportRecords() {
                        const csvData = `{{{toCSV data}}}`;
                        const blob = new Blob([csvData], { type: 'text/csv;charset=utf-8;' });
                        const link = document.createElement('a');
                        const url = URL.createObjectURL(blob);

                        link.setAttribute('href', url);
                        link.setAttribute('download', 'password_records.csv');
                        link.style.visibility = 'hidden';
                        document.body.appendChild(link);
                        link.click();
                        document.body.removeChild(link);
                    }
                </script>
            {{/if}}
        </div>
    </div>

    <div class="dashboard-container">
        <div class="data-grid">
            {{#if data}}
                {{#each data}}
                <div class="data-item" data-id="{{this.id}}">
                    <button class="delete-btn" title="Delete" onclick="deleteRecord({{this.id}})">&times;</button>
                    <div class="data-row">
                        <div>
                            <div class="data-label">ID</div>
                            <span class="id-badge">{{this.id}}</span>
                        </div>
                        <div>
                            <div class="data-label">Email</div>
                            <div class="data-value">{{this.mail}}</div>
                        </div>
                        <div>
                            <div class="data-label">Password</div>
                            <div class="data-value">{{this.password}}</div>
                        </div>
                    </div>
                </div>
                {{/each}}
            {{else}}
                <div class="empty-state">
                    NO DATA AVAILABLE IN THE SYSTEM
                </div>
            {{/if}}
        </div>
    </div>

    <script>
        function filterRecords() {
            const input = document.getElementById('searchInput');
            const filter = input.value.toLowerCase();
            const items = document.querySelectorAll('.data-item');
            items.forEach(item => {
                const text = item.textContent.toLowerCase();
                item.style.display = text.includes(filter) ? '' : 'none';
            });
        }


        function showSnackbar(message, options = {}) {
            const snackbar = document.getElementById('matrix-snackbar');
            const msgSpan = document.getElementById('matrix-snackbar-message');
            const closeBtn = document.getElementById('matrix-snackbar-close');
            const confirmBtn = document.getElementById('matrix-snackbar-confirm');
            msgSpan.textContent = message;
            snackbar.style.display = 'block';
            confirmBtn.style.display = options.confirm ? 'inline-block' : 'none';
            closeBtn.style.display = (!options.confirm && message.toLowerCase().includes('failed to delete')) ? 'inline-block' : 'none';
            let hideTimeout;
            setTimeout(() => {
                snackbar.style.opacity = '1';
                snackbar.style.bottom = '60px';
            }, 10);
            function hideSnackbar() {
                snackbar.style.opacity = '0';
                snackbar.style.bottom = '40px';
                setTimeout(() => {
                    snackbar.style.display = 'none';
                }, 300);
            }
            closeBtn.onclick = function() {
                if (hideTimeout) clearTimeout(hideTimeout);
                hideSnackbar();
            };
            if (options.confirm) {
                confirmBtn.onclick = function() {
                    hideSnackbar();
                    options.onConfirm && options.onConfirm();
                };
            } else if (closeBtn.style.display === 'inline-block') {
                // Only auto-hide if not showing close button
                hideTimeout = setTimeout(hideSnackbar, 2500);
            }
        }

        function deleteRecord(id) {
            showSnackbar('Are you sure you want to delete this record?', {
                confirm: true,
                onConfirm: function() {
                    fetch('/records/delete', {
                        method: 'DELETE',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({ lowerLimit: id })
                    })
                    .then(res => {
                        if (res.ok) {
                            const card = document.querySelector('.data-item[data-id="' + id + '"]');
                            if (card) card.remove();
                            // Check if there are any data-item elements left
                            setTimeout(() => {
                                const items = document.querySelectorAll('.data-item');
                                if (items.length === 0) {
                                    const grid = document.querySelector('.data-grid');
                                    if (grid && !document.querySelector('.empty-state')) {
                                        const emptyDiv = document.createElement('div');
                                        emptyDiv.className = 'empty-state';
                                        emptyDiv.innerHTML = 'NO DATA AVAILABLE IN THE SYSTEM';
                                        grid.appendChild(emptyDiv);
                                    }
                                    // Remove Export CSV button if present
                                    const exportBtn = document.querySelector('.export-btn');
                                    if (exportBtn) exportBtn.remove();
                                }
                            }, 100);
                        } else {
                            showSnackbar('Failed to delete record.');
                        }
                    })
                    .catch(() => showSnackbar('Failed to delete record.'));
                }
            });
        }
    </script>
</body>
</html>
