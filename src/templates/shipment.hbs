<html>
	<head>
		<style>
			:root {
				--colors-text-inverse: #ffffff;
				--colors-text-primary: #000000;
				--colors-text-subtle: #f7f7f7;
				--colors-bg-primary: #ffffff;
				--colors-bg-subtle: #000000;
				--colors-bg-accent: #1976d2;
				--colors-shadow-subtle: #e0e0e0;
			}

			body { font-family: Arial, sans-serif; background: var(--colors-bg-primary); margin: 0; padding: 0; }
			.container { background: var(--colors-bg-primary); max-width: 600px; margin: 30px auto; border-radius: 8px; box-shadow: 0 2px 8px var(--colors-shadow-subtle); padding: 32px; }
			.header { text-align: center; margin-bottom: 24px; }
			.header h1 { color: var(--colors-bg-accent); }
			.details { margin: 24px 0; }
			.details-table { width: 100%; border-collapse: collapse; }
			.details-table td { padding: 8px 0; color: var(--colors-text-primary); }
			.items { width: 100%; display: flex; flex-flow: column nowrap; justify-content: center; align-items: flex-start; gap: 8px; }
			.items ul li { width: 100%; display: flex; flex-flow: row nowrap; justify-content: flex-start; align-items: center; gap: 16px; }
			.items ul li img { width: 50px; height: 50px; object-fit: cover; border-radius: 4px; }
			.items ul { list-style: disc inside; color: var(--colors-text-primary) }
			.tracking { margin: 32px 0 0 0; text-align: center; }
			.tracking-link { display: inline-block; background: var(--colors-bg-accent); color: var(--colors-text-inverse); padding: 12px 24px; border-radius: 6px; text-decoration: none; font-size: 16px; }

			/* Custom bullets for flex list items */
			.items ul li {
				list-style: none;
				position: relative;
			}
			.items ul li::before {
				content: '\2022';
				color: var(--colors-text-primary);
				font-size: 1.2em;
				margin-right: 4px;
				display: inline-block;
				width: 16px;
				flex-shrink: 0;
			}
		</style>
	</head>
	<body>
		<div class="container">
			<div class="header">
				<h1>📦 Your Order Has Shipped!</h1>
				<p>Hi {{customerName}}, your order is on its way.</p>
			</div>
			<hr/>
			<div class="details">
				<table class="details-table">
					<tr>
						<td><strong>Order Number:</strong></td>
						<td>{{orderNumber}}</td>
					</tr>
					<tr>
						<td><strong>Shipping Address:</strong></td>
						<td>{{shippingAddress}}</td>
					</tr>
					<tr>
						<td><strong>Estimated Delivery:</strong></td>
						<td>{{estimatedDelivery}}</td>
					</tr>
				</table>
			</div>
			<div class="items">
				<h3>Items in your order:</h3>
				<ul>
					{{#each items}}
					<li>
						{{name}} (x{{quantity}})
						<img src="{{image}}" alt="{{name}}" />
					</li>
					{{/each}}
				</ul>
			</div>
			<div class="tracking">
				<a class="tracking-link" href="{{trackingUrl}}">Track Your Package</a>
			</div>
		</div>
	</body>
</html>
