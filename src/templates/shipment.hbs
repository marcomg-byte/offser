<html>
	<head>
		<style>
			body { font-family: Arial, sans-serif; background: #f7f7f7; margin: 0; padding: 0; }
			.container { background: #fff; max-width: 600px; margin: 30px auto; border-radius: 8px; box-shadow: 0 2px 8px #e0e0e0; padding: 32px; }
			.header { text-align: center; margin-bottom: 24px; }
			.header h1 { color: #222; }
			.details { margin: 24px 0; }
			.details-table { width: 100%; border-collapse: collapse; }
			.details-table td { padding: 8px 0; color: #444; }
			.tracking { margin: 32px 0 0 0; text-align: center; }
			.tracking-link { display: inline-block; background: #1976d2; color: #fff; padding: 12px 24px; border-radius: 6px; text-decoration: none; font-size: 16px; }
		</style>
	</head>
	<body>
		<div class="container">
			<div class="header">
				<h1>📦 Your Order Has Shipped!</h1>
				<p>Hi {{customerName}}, your order is on its way.</p>
			</div>
			<div class="details">
				<table class="details-table">
					<tr>
						<td><strong>Order Number:</strong></td>
						<td>{{orderNumber}}</td>
					</tr>
					<tr>
						<td><strong>Shipping Address:</strong></td>
						<td>{{shippingAddress}}</td>
					</tr>
					<tr>
						<td><strong>Estimated Delivery:</strong></td>
						<td>{{estimatedDelivery}}</td>
					</tr>
				</table>
			</div>
			<div>
				<h3>Items in your order:</h3>
				<ul>
					{{#each items}}
					<li>{{name}} (x{{quantity}})</li>
					{{/each}}
				</ul>
			</div>
			<div class="tracking">
				<a class="tracking-link" href="{{trackingUrl}}">Track Your Package</a>
			</div>
		</div>
	</body>
</html>
