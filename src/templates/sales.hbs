<html>
	<head>
		<style>
			body { font-family: Arial, sans-serif; background: #f7f7f7; margin: 0; padding: 0; }
			.container { background: #fff; max-width: 600px; margin: 30px auto; border-radius: 8px; box-shadow: 0 2px 8px #e0e0e0; padding: 32px; }
			.header { text-align: center; margin-bottom: 24px; }
			.header h1 { color: #222; }
			.offer-list { list-style: none; padding: 0; }
			.offer-item { display: flex; align-items: center; border-bottom: 1px solid #eee; padding: 16px 0; }
			.offer-item:last-child { border-bottom: none; }
			.sneaker-img { width: 80px; height: 80px; object-fit: cover; border-radius: 8px; margin-right: 24px; }
			.sneaker-info { flex: 1; }
			.sneaker-name { font-size: 18px; font-weight: bold; color: #333; }
			.sneaker-desc { color: #666; font-size: 14px; margin: 4px 0 8px 0; }
			.sneaker-price { color: #e53935; font-size: 16px; font-weight: bold; }
			.cta { display: block; width: 200px; margin: 32px auto 0 auto; background: #222; color: #fff; text-align: center; padding: 14px 0; border-radius: 6px; text-decoration: none; font-size: 16px; }
		</style>
	</head>
	<body>
		<div class="container">
			<div class="header">
				<h1>🔥 Sneaker Sale: Limited Time Offers! 🔥</h1>
				<p>Check out our latest sneaker deals just for you.</p>
			</div>
			<ul class="offer-list">
				{{#each offers}}
				<li class="offer-item">
					<img class="sneaker-img" src="{{image}}" alt="{{name}}" />
					<div class="sneaker-info">
						<div class="sneaker-name">{{name}}</div>
						<div class="sneaker-desc">{{description}}</div>
						<div class="sneaker-price">Now: ${{price}}</div>
					</div>
				</li>
				{{/each}}
			</ul>
			<a class="cta" href="{{ctaUrl}}">Shop Now</a>
		</div>
	</body>
</html>
